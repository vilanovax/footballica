# ============================================================
#  فوتبالیکا — نمونهٔ متغیرهای محیطی بک‌اند
#  این فایل را به .env کپی کن و مقادیر را پر کن.
# ============================================================

# Postgres (docker-compose پیش‌فرض همین را می‌سازد)
DATABASE_URL="postgresql://footballica:footballica@localhost:5432/footballica?schema=public"

# Redis (تایمر، قفل راند، لیدربورد)
REDIS_URL="redis://localhost:6379"

# پورت سرور
PORT=3000

# JWT (ورود با شماره). در پروداکشن حتماً یک مقدار تصادفیِ قوی بگذار.
JWT_SECRET="dev-secret-change-me"
JWT_EXPIRES_IN="30d"

# محیط اجرا؛ در غیرِ production کدِ OTP در پاسخ برمی‌گردد (برای تست).
NODE_ENV="development"

# کلیدِ پنلِ ادمین (MVP). در پروداکشن یک مقدار تصادفیِ قوی بگذار.
ADMIN_KEY="dev-admin-key"

# مبدأهای مجازِ CORS (کاما-جدا) برای پنلِ ادمین. خالی = همه (فقط برای dev).
# مثال prod: CORS_ORIGINS="https://admin.footballica.ir"
CORS_ORIGINS=""

# ============================================================
#  پادکستِ خودکار (podcast module)
# ============================================================

# زمان‌بندِ روزانه. برای فعال‌شدنِ اجرای خودکار روی 'true' بگذار.
PODCAST_CRON_ENABLED="false"
PODCAST_HOUR="8"        # ساعتِ تهران
PODCAST_MINUTE="0"

# پنجره‌های جمع‌آوریِ داده و سقفِ آیتم‌ها
PODCAST_NEWS_HOURS="24"
PODCAST_RESULT_HOURS="24"
PODCAST_WEEK_DAYS="7"
PODCAST_MAX_NEWS="5"
PODCAST_MAX_RESULTS="5"

# میزبان: gdrive | local
PODCAST_STORAGE="gdrive"

# --- Google Drive (وقتی PODCAST_STORAGE=gdrive) ---
# توکنِ OAuth2 با scopeِ drive.file؛ باید بیرون تازه (refresh) نگه داشته شود.
GDRIVE_ACCESS_TOKEN=""
GDRIVE_FOLDER_ID=""     # اختیاری: پوشهٔ مقصد

# --- میزبانِ محلی (وقتی PODCAST_STORAGE=local) ---
PODCAST_PUBLIC_DIR=""                          # پیش‌فرض: <cwd>/public/podcast
PODCAST_PUBLIC_BASE_URL="http://localhost:3000/podcast/media"

# متادیتای فیدِ RSS
PODCAST_TITLE="پادکست روزانهٔ فوتبالیکا"
PODCAST_DESCRIPTION="مهم‌ترین اخبار، نتایج و بازی‌های فوتبال — تولیدِ خودکار و روزانه."
PODCAST_AUTHOR="فوتبالیکا"
PODCAST_LINK="https://footballica.example"
PODCAST_IMAGE=""
PODCAST_LANGUAGE="fa-IR"
PODCAST_FEED_URL="http://localhost:3000/podcast/feed.xml"
