# ============================================================
#  فوتبالیکا — نمونهٔ متغیرهای محیطی بک‌اند
#  این فایل را به .env کپی کن و مقادیر را پر کن.
# ============================================================

# Postgres (docker-compose پیش‌فرض همین را می‌سازد)
DATABASE_URL="postgresql://footballica:footballica@localhost:5432/footballica?schema=public"

# Redis (تایمر، قفل راند، لیدربورد)
REDIS_URL="redis://localhost:6379"

# پورت سرور
PORT=3000

# JWT (ورود با شماره). در پروداکشن حتماً یک مقدار تصادفیِ قوی بگذار.
JWT_SECRET="dev-secret-change-me"
JWT_EXPIRES_IN="30d"

# محیط اجرا؛ در غیرِ production کدِ OTP در پاسخ برمی‌گردد (برای تست).
NODE_ENV="development"

# کلیدِ پنلِ ادمین (MVP). در پروداکشن یک مقدار تصادفیِ قوی بگذار.
ADMIN_KEY="dev-admin-key"
