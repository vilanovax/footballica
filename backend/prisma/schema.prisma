// ============================================================
//  فوتبالیکا — schema.prisma  (هستهٔ بازی، فاز ۰–۱)
//  این فایل را Cursor/Claude Code به‌عنوان نقطهٔ شروعِ دیتابیس می‌گیرد.
//  فقط جدول‌های لازم برای حلقهٔ اصلی + لیدربورد. بقیه (economy,
//  achievements, season) در فاز بعد اضافه می‌شوند.
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// درجهٔ سختیِ ربات — دقتِ پاسخ و سرعتِ شبیه‌سازی‌شده را تعیین می‌کند.
enum BotDifficulty {
  EASY
  MEDIUM
  HARD
}

// ---------- کاربر ----------
// نکته: ربات‌ها هم رکوردِ User هستند (تا در دوئل مثل بازیکنِ واقعی رفتار کنند
// و از کلاینت قابل‌تشخیص نباشند). فرقشان فقط isBot/botDifficulty است که
// هرگز در پاسخِ APIِ کلاینت فاش نمی‌شود.
model User {
  id        String   @id @default(cuid())
  phone     String   @unique          // ورود با شماره (رایج در ایران)
  name      String?
  avatar    String?
  level     Int      @default(1)
  xp        Int      @default(0)

  // ---- اقتصاد (سه ارز + جان) ----
  coins     Int      @default(0)   // 🪙 ارزِ عمومی
  fans      Int      @default(0)   // 🎽 هوادار/شهرت (از بردِ دوئل)
  cards     Int      @default(0)   // ⚡ کارت/جوکر (کمیاب)
  lives     Int      @default(5)   // ❤️
  lastLifeRegenAt DateTime @default(now()) // مبنای محاسبهٔ بازیابیِ جان

  // ---- استریکِ روزانه ----
  streakCurrent Int     @default(0)
  streakLongest Int     @default(0)
  streakLastDay String? // آخرین روزِ claim به‌صورت 'YYYY-MM-DD' (وقتِ تهران)

  createdAt DateTime @default(now())

  // ---- ربات (فقط سمتِ سرور؛ به کلاینت لو نمی‌رود) ----
  isBot         Boolean        @default(false)
  botDifficulty BotDifficulty?

  matchesAsPlayer   MatchPlayer[]
  answers           Answer[]
  duelRounds        DuelRound[]
  walletTransactions WalletTransaction[]
  achievements      UserAchievement[]

  @@index([isBot])
  @@map("users")
}

// ---------- بانک سؤال ----------
enum Difficulty {
  EASY
  MEDIUM
  HARD
}

model Question {
  id          String     @id @default(cuid())
  text        String
  difficulty  Difficulty @default(MEDIUM)
  categoryId  String?
  category    Category?  @relation(fields: [categoryId], references: [id])
  // فیلدِ منعطف: منبع، فصل، payload فوتبالی → jsonb با ایندکس GIN
  metadata    Json       @default("{}")
  isApproved  Boolean    @default(false)   // ادمین تأیید می‌کند
  options     QuestionOption[]
  answers     Answer[]
  rounds      MatchRound[]
  duelQuestions DuelQuestion[]
  duelRounds  DuelRound[]
  createdAt   DateTime   @default(now())

  @@index([metadata], type: Gin)
  @@map("questions")
}

model QuestionOption {
  id         String   @id @default(cuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  text       String
  // ⚠️ این فیلد هرگز در پاسخِ APIِ کلاینت قرار نمی‌گیرد (server-authoritative)
  isCorrect  Boolean  @default(false)
  order      Int

  @@map("question_options")
}

model Category {
  id        String     @id @default(cuid())
  name      String     // لیگ برتر، جام جهانی، لیگ قهرمانان...
  slug      String     @unique
  questions Question[]

  @@map("question_categories")
}

// ---------- مَچ و راند ----------
enum GameMode {
  QUICK     // بازی سریع تک‌نفره
  BOMB      // حالت بمب
  DUEL      // دوئل async (فاز ۲)
}

enum MatchStatus {
  WAITING   // دوئل: منتظرِ حریف
  ACTIVE
  FINISHED
  ABANDONED
}

model Match {
  id        String      @id @default(cuid())
  mode      GameMode
  status    MatchStatus @default(ACTIVE)
  totalRounds Int       @default(5)
  createdAt DateTime    @default(now())
  finishedAt DateTime?

  players       MatchPlayer[]
  rounds        MatchRound[]
  duelQuestions DuelQuestion[]
  duelRounds    DuelRound[]

  @@map("matches")
}

model MatchPlayer {
  id       String @id @default(cuid())
  matchId  String
  match    Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation(fields: [userId], references: [id])
  score    Int    @default(0)
  isWinner Boolean?

  @@unique([matchId, userId])
  @@map("match_players")
}

model MatchRound {
  id          String   @id @default(cuid())
  matchId     String
  match       Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  questionId  String
  question    Question @relation(fields: [questionId], references: [id])
  roundIndex  Int      // ۰..۴
  // ⏱ منبعِ حقیقتِ زمان — سرور پر می‌کند، نه کلاینت
  startedAt   DateTime @default(now())
  deadlineAt  DateTime // startedAt + مدتِ مود
  answers     Answer[]

  @@unique([matchId, roundIndex])
  @@map("match_rounds")
}

model Answer {
  id         String     @id @default(cuid())
  roundId    String
  round      MatchRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
  questionId String
  question   Question   @relation(fields: [questionId], references: [id])
  userId     String
  user       User       @relation(fields: [userId], references: [id])
  optionId   String?    // انتخابِ کاربر؛ null یعنی زمان تمام شد
  isCorrect  Boolean    @default(false) // سرور تعیین می‌کند
  msTaken    Int        // میلی‌ثانیه از startedAt تا دریافت پاسخ (سمت سرور)
  points     Int        @default(0)
  createdAt  DateTime   @default(now())

  @@unique([roundId, userId])
  @@map("answers")
}

// ---------- دوئل async (فاز ۲) ----------
// مجموعهٔ ثابتِ سؤالِ یک دوئل — هر دو بازیکن به همین‌ها جواب می‌دهند
// تا مقایسه منصفانه باشد.
model DuelQuestion {
  id         String   @id @default(cuid())
  matchId    String
  match      Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  questionId String
  question   Question @relation(fields: [questionId], references: [id])
  order      Int      // ۰..N-1

  @@unique([matchId, order])
  @@map("duel_questions")
}

// راندِ یک بازیکن روی یک سؤالِ دوئل — تایمرِ مستقلِ هر بازیکن
// (ناهم‌زمان). isCorrect و امتیاز را سرور تعیین می‌کند.
model DuelRound {
  id         String    @id @default(cuid())
  matchId    String
  match      Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  questionId String
  question   Question  @relation(fields: [questionId], references: [id])
  order      Int
  startedAt  DateTime  @default(now())
  deadlineAt DateTime
  optionId   String?
  isCorrect  Boolean   @default(false)
  msTaken    Int?
  points     Int       @default(0)
  answeredAt DateTime?

  @@unique([matchId, userId, order])
  @@map("duel_rounds")
}

// ---------- اقتصاد ----------
enum Currency {
  COINS
  FANS
  CARDS
  LIVES
}

// دفترِ تراکنش‌های کیف‌پول — برای ردیابی و رفعِ اختلاف (audit).
// amount مثبت = کسب، منفی = خرج.
model WalletTransaction {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  currency  Currency
  amount    Int
  reason    String // مثلاً: duel_win, quick_finish, refill_lives
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@map("wallet_transactions")
}

// ---------- اچیومنت ----------
// تعریفِ اچیومنت‌ها در کد است (achievements.constants.ts)؛ این جدول فقط
// «باز شدن» را برای هر کاربر ثبت می‌کند.
model UserAchievement {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  key        String // کلیدِ اچیومنت (مثلاً correct_100)
  unlockedAt DateTime @default(now())

  @@unique([userId, key])
  @@map("user_achievements")
}

// ---------- پادکستِ خودکار ----------
// هر اجرای روزانهٔ پایپلاین یک اپیزود می‌سازد؛ فیدِ RSS از همین جدول ساخته
// می‌شود. audioUrl نشانیِ عمومیِ فایل (Google Drive/محلی) است.
model PodcastEpisode {
  id              String   @id @default(cuid())
  title           String
  description     String
  audioUrl        String // enclosure در RSS
  mimeType        String   @default("audio/wav")
  byteSize        Int      @default(0)
  durationSec     Int      @default(0)
  scriptText      String // متنِ گویندگی (SSML) — برای بازبینی/بازتولید
  storageProvider String   @default("local") // local | gdrive
  externalId      String? // شناسهٔ فایل در میزبان (fileId گوگل‌درایو)
  sourceMeta      Json     @default("{}") // شمارشِ اخبار/نتایج/بازی‌ها + تریگر
  publishedAt     DateTime @default(now())

  @@index([publishedAt])
  @@map("podcast_episodes")
}

// لیدربورد در Redis Sorted Set نگه‌داری می‌شود؛ این جدول فقط
// اسنپ‌شاتِ فصلی برای آرشیو است.
model LeaderboardSnapshot {
  id        String   @id @default(cuid())
  userId    String
  season    String
  rank      Int
  score     Int
  takenAt   DateTime @default(now())

  @@index([season, rank])
  @@map("leaderboard_snapshots")
}
